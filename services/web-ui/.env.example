# Base URL of the KubePilot api-gateway. No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Phase 1 single-key auth. Sent as the `X-API-Key` header on every request.
# NOTE: This is a NEXT_PUBLIC_ var, so it is exposed to the browser bundle.
# That is acceptable for the Phase 1 self-hosted MVP; do not use a shared
# production secret here for anything beyond a single-tenant deployment.
NEXT_PUBLIC_API_KEY=dev-local-key
